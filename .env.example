PORT=4000
NODE_ENV=production

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gl_api
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=true

# JWT — use a random 64-char string in production
JWT_SECRET=change-this-to-a-random-64-char-secret
JWT_EXPIRES_IN=12h

FRONTEND_URL=https://your-frontend-domain.com
